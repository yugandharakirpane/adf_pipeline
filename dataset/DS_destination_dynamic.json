{
	"name": "DS_destination_dynamic",
	"properties": {
		"linkedServiceName": {
			"referenceName": "LS_STORAGE",
			"type": "LinkedServiceReference"
		},
		"parameters": {
			"p_destination_folder": {
				"type": "String"
			},
			"p_filename": {
				"type": "String"
			}
		},
		"annotations": [],
		"type": "DelimitedText",
		"typeProperties": {
			"location": {
				"type": "AzureBlobFSLocation",
				"fileName": {
					"value": "@dataset().p_filename",
					"type": "Expression"
				},
				"folderPath": {
					"value": "@concat('bronze/',dataset().p_destination_folder)\n\n",
					"type": "Expression"
				},
				"fileSystem": "awproject"
			},
			"columnDelimiter": ",",
			"escapeChar": "\\",
			"firstRowAsHeader": true,
			"quoteChar": "\""
		},
		"schema": []
	}
}